---
import Layout from '../layouts/Layout.astro';
import JobitApp from '../components/JobitApp';
import { createServerClient, parseCookieHeader } from '@supabase/ssr';

const supabase = createServerClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  {
    cookies: {
      getAll() {
        return parseCookieHeader(Astro.request.headers.get('Cookie') ?? '');
      },
      setAll(cookiesToSet) {
        cookiesToSet.forEach(({ name, value, options }: any) =>
          Astro.cookies.set(name, value, options)
        );
      },
    },
  }
);

const { data: { session }, error: sessionError } = await supabase.auth.getSession();
const incomingCookieNames = parseCookieHeader(Astro.request.headers.get('Cookie') ?? '').map((c: any) => c.name);
const hasAuthToken = incomingCookieNames.some((n: string) => n.includes('auth-token') && !n.includes('verifier'));
console.log(`[index] session=${!!session} hasAuthToken=${hasAuthToken} cookies=${incomingCookieNames.join(',')} err=${sessionError?.message ?? 'none'}`);
if (!session) return Astro.redirect('/login');
---
<Layout title="Jobit">
  <JobitApp client:load />
</Layout>
